{
  "info": {
    "name": "AutoClean Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para testar o backend ASP.NET Core do AutoClean Manager."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5057" },
    { "key": "userId", "value": "1" },
    { "key": "vehicleId", "value": "1" },
    { "key": "washTypeId", "value": "1" },
    { "key": "appointmentId", "value": "1" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "GET - List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "GET - User By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "POST - Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('userId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bruna Costa\",\n  \"email\": \"bruna.costa@email.com\",\n  \"role\": \"Cliente\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "PUT - Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bruna Costa Atualizada\",\n  \"email\": \"bruna.costa@email.com\",\n  \"role\": \"Cliente\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "DELETE - User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
