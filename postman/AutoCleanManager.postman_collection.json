{
  "info": {
    "name": "API AutoClean Manager",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colecao para testar o backend ASP.NET Core do AutoClean Manager."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5057" },
    { "key": "usuarioId", "value": "1" },
    { "key": "veiculoId", "value": "1" },
    { "key": "tipoLavagemId", "value": "1" },
    { "key": "appointmentId", "value": "1" }
  ],
  "item": [
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "GET - Listar Usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/usuarios"
          }
        },
        {
          "name": "GET - Buscar Usuario por Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/usuarios/{{usuarioId}}"
          }
        },
        {
          "name": "POST - Criar Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('usuarioId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Bruna Costa\",\n  \"email\": \"bruna.costa@email.com\",\n  \"papel\": \"Cliente\"\n}"
            },
            "url": "{{baseUrl}}/api/usuarios"
          }
        },
        {
          "name": "PUT - Atualizar Usuario",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Bruna Costa Atualizada\",\n  \"email\": \"bruna.costa@email.com\",\n  \"papel\": \"Cliente\"\n}"
            },
            "url": "{{baseUrl}}/api/usuarios/{{usuarioId}}"
          }
        },
        {
          "name": "DELETE - Excluir Usuario",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/usuarios/{{usuarioId}}"
          }
        }
      ]
    },
